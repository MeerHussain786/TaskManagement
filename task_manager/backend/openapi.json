pleted", "in": "query", "required": false, "schema": {"anyOf": [{"type": "boolean"}, {"type": "null"}], "description": "Filter by completion status", "title": "Completed"}, "description": "Filter by completion status"}, {"name": "priority", "in": "query", "required": false, "schema": {"anyOf": [{"$ref": "#/components/schemas/TaskPriority"}, {"type": "null"}], "description": "Filter by priority", "title": "Priority"}, "description": "Filter by priority"}, {"name": "due_before", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string", "format": "date"}, {"type": "null"}], "description": "Filter tasks due on/before date", "title": "Due Before"}, "description": "Filter tasks due on/before date"}, {"name": "due_after", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string", "format": "date"}, {"type": "null"}], "description": "Filter tasks due on/after date", "title": "Due After"}, "description": "Filter tasks due on/after date"}, {"name": "search", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "description": "Text search on title/description", "title": "Search"}, "description": "Text search on title/description"}, {"name": "sort_by", "in": "query", "required": false, "schema": {"enum": ["created_at", "due_date", "priority", "title"], "type": "string", "description": "Property to sort by", "default": "created_at", "title": "Sort By"}, "description": "Property to sort by"}, {"name": "order", "in": "query", "required": false, "schema": {"enum": ["asc", "desc"], "type": "string", "description": "Sort ordering", "default": "desc", "title": "Order"}, "description": "Sort ordering"}, {"name": "page", "in": "query", "required": false, "schema": {"type": "integer", "minimum": 1, "description": "Page number", "default": 1, "title": "Page"}, "description": "Page number"}, {"name": "page_size", "in": "query", "required": false, "schema": {"type": "integer", "maximum": 100, "minimum": 1, "description"